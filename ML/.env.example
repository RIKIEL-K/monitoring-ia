# =============================================================================
# AIOps ML — Configuration
# =============================================================================
# Copier : cp .env.example .env
# Adapter l'IP de Prometheus puis c'est prêt.
# =============================================================================

# --- Prometheus ---
# IP PRIVÉE de l'EC2 Observabilité (même VPC, port 9090)
# Console AWS > EC2 > Instance Observabilité > Private IPv4
PROMETHEUS_URL=http://10.0.1.XX:9090

# --- Modèle IsolationForest ---
# Utilisé par : train_model.py, detect_anomalie.py
MODEL_PATH=/home/ubuntu/monitoring-ia/ML/models/anomaly_model.pkl

# --- Modèles Prophet ---
# Utilisé par : train_forcasting_model.py, forecast_metrics.py
MODEL_DIR=/home/ubuntu/monitoring-ia/ML/models/prophet

# --- Prédictions ---
# Horizon de forecast en jours (utilisé par forecast_metrics.py)
FORECAST_DAYS=7
