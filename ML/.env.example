# =============================================================================
# AIOps ML — Configuration (.env)
# =============================================================================
# Ce fichier est lu par les scripts ML sur l'EC2 Agent.
# Copier ce fichier : cp .env.example .env  puis adapter les valeurs.
# =============================================================================

# --- Prometheus (tourne sur l'EC2 Observabilité) ---
# Utiliser l'IP PRIVÉE de l'EC2 Observabilité (même VPC)
# Trouver l'IP : Console AWS > EC2 > Instance Observabilité > Private IPv4
PROMETHEUS_URL=http://<IP_PRIVEE_EC2_OBSERVABILITE>:9090

# --- Paths (sur l'EC2 Agent) ---
MODEL_PATH=/opt/ml/models/anomaly_model.pkl
MODEL_DIR=/opt/ml/models/prophet

# --- Seuils d'alerte (%) ---
CPU_THRESHOLD=85
RAM_THRESHOLD=90
DISK_THRESHOLD=90
