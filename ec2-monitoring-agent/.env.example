# =============================================================================
# EC2 Monitoring Agent — Configuration
# =============================================================================

# --- Connectivité vers l'EC2 Observabilité ---
# Utiliser l'IP PRIVÉE de l'EC2 qui héberge Prometheus et Loki.
# Les deux instances doivent être dans le même VPC.
# Security Group de l'EC2 Observabilité doit autoriser:
#   - TCP 9090 (Prometheus) depuis le SG de l'agent
#   - TCP 3100 (Loki) depuis le SG de l'agent
LOKI_URL=http://<IP_PRIVEE_EC2_OBSERVABILITE>:3100
PROMETHEUS_URL=http://<IP_PRIVEE_EC2_OBSERVABILITE>:9090

# IP/URL de l'application cible (pour les health checks de l'agent)
TARGET_APP_URL=http://<IP_PRIVEE_EC2_TARGET_APP>:8080

# Timeout en secondes pour les requêtes vers Prometheus/Loki
REQUEST_TIMEOUT=10

# --- AWS ---
AWS_REGION=us-east-1

# --- Agent Monitoring MLOps ---
# Intervalle entre les cycles de monitoring (en minutes)
MONITORING_INTERVAL_MINUTES=5

# Nombre max d'itérations par cycle
AGENT_MAX_ITERATIONS=10

# Démarrer automatiquement le monitoring au lancement (true/false)
AGENT_AUTO_START=false
